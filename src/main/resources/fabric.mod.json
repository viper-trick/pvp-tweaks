{
  "schemaVersion": 1,
  "id": "pvptweaks",
  "version": "${version}",

  "name": "PVP Tweaks",
  "description": "Fine-tune End Crystal size, explosion sounds, and PVP particles via a clean GUI.",
  "authors": [ "YourName" ],
  "contact": {
    "homepage": "https://github.com/yourname/pvp-tweaks",
    "issues":   "https://github.com/yourname/pvp-tweaks/issues"
  },

  "license": "MIT",
  "icon":    "assets/pvptweaks/icon.png",

  "environment": "client",

  "entrypoints": {
    "main":    [ "com.pvptweaks.PvpTweaksMod"               ],
    "client":  [ "com.pvptweaks.PvpTweaksClient"            ],
    "modmenu": [ "com.pvptweaks.integration.ModMenuIntegration" ]
  },

  "mixins": [ "pvptweaks.mixins.json" ],

  "depends": {
    "fabricloader": ">=0.18.4",
    "fabric-api":   "*",
    "minecraft":    "~1.21.11",
    "cloth-config": "*",
    "modmenu":      "*"
  }
}
