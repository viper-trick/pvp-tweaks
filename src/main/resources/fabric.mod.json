{
  "schemaVersion": 1,
  "id": "pvptweaks",
  "version": "${version}",

  "name": "PVP Tweaks",
  "description": "Comprehensive PVP performance and visual optimizations including Crystal/Anchor lag mitigation, HUD adjusters, and custom combat visuals.",
  "authors": [ "viper-trick" ],
  "contact": {
    "homepage": "https://github.com/viper-trick/pvp-tweaks",
    "issues":   "https://github.com/viper-trick/pvp-tweaks/issues"
  },

  "license": "MIT",

  "icon": "icon.png",

  "environment": "client",

  "entrypoints": {
    "main":    [ "com.pvptweaks.PvpTweaksMod"               ],
    "client":  [ "com.pvptweaks.PvpTweaksClient"            ],
    "modmenu": [ "com.pvptweaks.integration.ModMenuIntegration" ]
  },

  "mixins": [ "pvptweaks.mixins.json" ],

  "depends": {
    "fabricloader": ">=0.18.4",
    "fabric-api":   "*",
    "minecraft":    "~1.21.11",
    "cloth-config": "*",
    "modmenu":      "*"
  }
}
